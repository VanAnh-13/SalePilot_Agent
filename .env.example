# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_NAME=gpt-4o-mini

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/salepilot.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CHROMA_PATH=./data/chroma

# Local MCP bridge: required only to create CRM leads through MCP.
MCP_WRITE_TOKEN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Zalo OA (stub)
ZALO_ENABLED=true
ZALO_CLIENT=mock
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET=
ZALO_WEBHOOK_SECRET=
ZALO_VERIFY_MODE=off

# Features
MEMORY_ENABLED=true
AUTO_SKILL_WRITE=false
SANDBOX_ENABLED=true
WEB_FETCH_ENABLED=true
SCHEDULER_ENABLED=true
TRAJECTORY_ENABLED=true
MAX_SUBAGENTS_PER_TURN=3
